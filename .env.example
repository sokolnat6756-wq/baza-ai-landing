# Порт локального сервера
PORT=3000

# Базовый URL сайта (для ссылок после оплаты)
SITE_URL=http://localhost:3000

# Тестовый режим: true — без реального Т-Банка, redirect на payment-success.html
MOCK_PAYMENTS=true

# Базовая цена в копейках (4500 ₽)
BASE_PRICE=450000

# Т-Банк (заполнить при реальном подключении)
TBANK_TERMINAL_KEY=
TBANK_SECRET_KEY=
TBANK_API_URL=https://securepay.tinkoff.ru/v2

# SMTP (заполнить при подключении email)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_SUPPORT=Y-kopasova@inbox.ru

# Ссылка на Telegram после оплаты
TELEGRAM_ACCESS_URL=
